<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/inputIngrediente"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_rounded"
            android:fontFamily="@font/be_vietnam_pro"
            android:hint="Ingrediente"
            android:inputType="textCapSentences"
            android:paddingHorizontal="10dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#BDBDBD"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/inputCantidad"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="0.6"
            android:background="@drawable/bg_input_rounded"
            android:fontFamily="@font/be_vietnam_pro"
            android:hint="Cant."
            android:inputType="text"
            android:paddingHorizontal="10dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#BDBDBD"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btnEliminarIngrediente"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Eliminar ingrediente"
            android:src="@android:drawable/ic_delete"
            app:tint="#BDBDBD" />

    </LinearLayout>